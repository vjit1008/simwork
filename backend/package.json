{
  "name": "simwork-backend",
  "version": "1.0.0",
  "description": "SimWork AI-Powered HR Interview Simulation Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testEnvironment=node --forceExit --detectOpenHandles --verbose",
    "test:watch": "jest --watch --verbose",
    "test:coverage": "jest --coverage --forceExit --verbose"
  },
  "jest": {
  "testEnvironment": "node",
